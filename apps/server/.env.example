NODE_ENV=development
PORT=3000

DATABASE_URL="mysql://mall:mall_password@localhost:3306/mall_system"
SHADOW_DATABASE_URL="mysql://mall:mall_password@localhost:3306/mall_system_shadow"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=Admin123456

UPLOAD_LOCAL_DIR=uploads
PUBLIC_BASE_URL=
UPLOAD_STORAGE=local

# Production preflight manual confirmations. Set to 1 after the corresponding
# production runbook/checklist item is actually prepared.
DATABASE_BACKUP_CONFIRMED=
LOG_RETENTION_CONFIRMED=
ERROR_MONITORING_CONFIRMED=
ROLLBACK_PLAN_CONFIRMED=

TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=

# WeChat miniapp login. Keep mock for local smoke tests.
WECHAT_LOGIN_MODE=mock
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_SECRET=

# WeChat Pay. Real prepay/notify signing is prepared as a P5 follow-up.
WECHAT_PAY_MODE=mock
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PLATFORM_SERIAL_NO=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=
